---
// Light/dark toggle. Persists to localStorage; the pre-paint script in Base.astro
// applies the stored theme before first render to avoid a flash.
---
<button class="theme-toggle" type="button" aria-label="Toggle colour theme" title="Toggle light / dark">
  <svg class="i-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4.2" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
  <svg class="i-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 14.5A8 8 0 1 1 9.5 4a6.2 6.2 0 0 0 10.5 10.5Z" />
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-grid; place-items: center;
    width: 40px; height: 40px;
    background: transparent; border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--ink); cursor: pointer;
    transition: border-color 0.18s var(--ease), color 0.18s var(--ease), background 0.18s var(--ease);
  }
  .theme-toggle:hover { border-color: var(--accent); color: var(--accent-strong); background: var(--surface); }
  .theme-toggle svg { grid-area: 1 / 1; }
  .i-moon { display: none; }
  :root[data-theme='dark'] .i-sun { display: none; }
  :root[data-theme='dark'] .i-moon { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .i-sun { display: none; }
    :root:not([data-theme='light']) .i-moon { display: block; }
  }
</style>

<script>
  const btn = document.currentScript?.previousElementSibling as HTMLElement | null;
  document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach((el) => {
    el.addEventListener('click', () => {
      const root = document.documentElement;
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const current = root.getAttribute('data-theme') || (prefersDark ? 'dark' : 'light');
      const next = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  });
</script>
