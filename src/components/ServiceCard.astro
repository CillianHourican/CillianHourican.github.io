---
interface Props { title: string; body: string; icon?: string; }
const { title, body, icon = 'node' } = Astro.props;

const icons: Record<string, string> = {
  node: '<circle cx="6" cy="6" r="2.4"/><circle cx="18" cy="7" r="2.4"/><circle cx="12" cy="18" r="2.4"/><path d="M7.7 7.2 16.3 8M7.2 7.6l4 8.2M16.6 9l-4 7"/>',
  chart: '<path d="M4 20V6M4 20h16M8 20v-6M12 20v-9M16 20v-4"/>',
  brain: '<path d="M9 4a3 3 0 0 0-3 3 3 3 0 0 0-1 5.8V16a3 3 0 0 0 4 2.8M15 4a3 3 0 0 1 3 3 3 3 0 0 1 1 5.8V16a3 3 0 0 1-4 2.8M9 4v15M15 4v15"/>',
  teach: '<path d="M3 8l9-4 9 4-9 4-9-4Z"/><path d="M7 10.5V15c0 1.4 2.2 2.5 5 2.5s5-1.1 5-2.5v-4.5"/><path d="M21 8v5"/>',
};
---
<div class="card card--link service">
  <span class="svc-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[icon] ?? icons.node} />
  </span>
  <h3 class="svc-title">{title}</h3>
  <p class="svc-body muted">{body}</p>
</div>

<style>
  .service { display: flex; flex-direction: column; gap: 0.7rem; height: 100%; }
  .svc-icon { display: inline-grid; place-items: center; width: 46px; height: 46px; border-radius: 11px; background: var(--tag-bg); color: var(--accent-strong); }
  .svc-title { font-size: var(--fs-400); }
  .svc-body { font-size: 0.96rem; max-width: none; }
</style>
