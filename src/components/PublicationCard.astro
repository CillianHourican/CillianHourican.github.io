---
interface Pub {
  title: string;
  authors: string;
  venue: string;
  year: number;
  tldr: string;
  doi?: string;
  url?: string;
  pdf?: string;
  code?: string;
  arxiv?: string;
  preprint?: boolean;
  first?: boolean;
  jointFirst?: boolean;
}
const { pub } = Astro.props as { pub: Pub };
const authorsHtml = pub.authors.replaceAll('Hourican, C.', '<strong>Hourican,&nbsp;C.</strong>');
const primary = pub.url ?? (pub.doi ? `https://doi.org/${pub.doi}` : undefined);
const links = [
  primary && { label: pub.preprint ? 'View' : 'DOI', href: primary },
  pub.pdf && { label: 'PDF', href: pub.pdf },
  pub.code && { label: 'Code', href: pub.code },
  pub.arxiv && { label: 'Preprint', href: pub.arxiv },
].filter(Boolean) as { label: string; href: string }[];
---
<article class="card pub-card">
  <div class="pub-meta">
    <p class="pub-venue mono"><span class="venue">{pub.venue}</span> · {pub.year}</p>
    {pub.first && <span class="first-badge">{pub.jointFirst ? 'Joint first author' : 'First author'}</span>}
  </div>
  <h3 class="pub-title">
    {primary ? <a href={primary} target="_blank" rel="noopener">{pub.title}</a> : pub.title}
  </h3>
  <p class="pub-authors" set:html={authorsHtml} />
  <p class="pub-tldr">{pub.tldr}</p>
  {links.length > 0 && (
    <div class="pub-links">
      {links.map((l) => (
        <a class="pub-link" href={l.href} target="_blank" rel="noopener">
          {l.label}<span aria-hidden="true"> ↗</span>
        </a>
      ))}
    </div>
  )}
</article>

<style>
  .pub-card { display: flex; flex-direction: column; gap: 0.55rem; height: 100%; }
  .pub-meta { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }
  .pub-venue { font-size: 0.8rem; color: var(--muted); margin: 0; }
  .pub-venue .venue { color: var(--pop-strong); font-weight: 500; }
  .first-badge { font-size: 0.66rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent-strong); background: var(--tag-bg); padding: 0.2rem 0.5rem; border-radius: 5px; white-space: nowrap; }
  .pub-title { font-size: var(--fs-400); line-height: 1.28; }
  .pub-title a { color: inherit; text-decoration: none; }
  .pub-title a:hover { color: var(--accent-strong); text-decoration: underline; text-decoration-color: var(--pop); text-underline-offset: 3px; }
  .pub-authors { font-size: 0.85rem; color: var(--muted); margin: 0; max-width: none; }
  .pub-authors :global(strong) { color: var(--ink); font-weight: 600; }
  .pub-tldr { font-size: 0.96rem; color: var(--ink); margin: 0; max-width: none; }
  .pub-links { display: flex; flex-wrap: wrap; gap: 0.4rem 0.5rem; margin-top: auto; padding-top: 0.35rem; }
  .pub-link {
    font-family: var(--font-mono); font-size: 0.74rem; font-weight: 500;
    color: var(--accent-strong); text-decoration: none;
    border: 1px solid var(--border); border-radius: 6px; padding: 0.24rem 0.55rem;
    transition: border-color 0.15s var(--ease), color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .pub-link:hover { border-color: var(--accent); background: var(--tag-bg); color: var(--tag-ink); }
</style>
