---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const teaching = (await getCollection('teaching')).map((e) => e.data).sort((a, b) => b.order - a.order);
const supervision = (await getCollection('supervision')).map((e) => e.data);
const daily = supervision
  .filter((s) => s.role === 'Daily supervisor')
  .sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
const assessed = supervision
  .filter((s) => s.role === 'Assessor')
  .sort((a, b) => a.student.localeCompare(b.student));
---
<Base title="Teaching & Supervision — Cillian Hourican" description="Teaching and student-project supervision by Cillian Hourican at the University of Amsterdam and Trinity College Dublin.">
  <section class="section container">
    <div class="section-head">
      <p class="eyebrow">Teaching & Supervision</p>
      <h1>Explaining complex methods, clearly.</h1>
      <p class="muted">Several years of lecturing, tutoring and supervising in computational science — the same instinct that shapes how I consult.</p>
    </div>

    <h2 class="sub">Courses</h2>
    <ul class="teach-list">
      {teaching.map((t) => (
        <li class="card teach-item">
          <div class="teach-main">
            <h3>{t.course}</h3>
            <p class="teach-prog muted">{t.programme} · {t.institution}</p>
            <p class="teach-desc">{t.description}</p>
          </div>
          <div class="teach-side">
            <span class="teach-years mono">{t.years}</span>
            <span class="tag">{t.role}</span>
          </div>
        </li>
      ))}
    </ul>

    <h2 class="sub sup-head">Student supervision</h2>
    <p class="muted sup-intro">Master's thesis projects I supervised day-to-day at the University of Amsterdam.</p>
    <div class="grid grid-2">
      {daily.map((s) => (
        <article class="card sup-item">
          <div class="sup-top">
            <span class="tag">{s.level} · Daily supervisor</span>
            {s.year && <span class="mono sup-year">{s.year}</span>}
          </div>
          <h3 class="sup-title">{s.student}</h3>
          {s.projectTitle && <p class="sup-project">“{s.projectTitle}”</p>}
          <p class="sup-student">{s.programme}</p>
          {s.blurb && <p class="sup-blurb muted">{s.blurb}</p>}
          {s.url && <a class="sup-link" href={s.url} target="_blank" rel="noopener">Details ↗</a>}
        </article>
      ))}
    </div>

    {assessed.length > 0 && (
      <div class="assess">
        <h2 class="sub sup-head">Second supervisor / assessor</h2>
        <p class="muted sup-intro">Master's and bachelor's theses where I acted as second supervisor or assessor at the University of Amsterdam.</p>
        <ul class="assess-list">
          {assessed.map((s) => (
            <li class:list={['assess-item', { 'has-title': s.projectTitle }]}>
              <span class="assess-name">{s.student}{s.year ? <span class="assess-year mono"> · {s.year}</span> : null}</span>
              {s.projectTitle
                ? <a class="assess-title" href={s.url} target="_blank" rel="noopener">{s.projectTitle} ↗</a>
                : null}
              <span class="assess-prog muted">{s.programme}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
</Base>

<style>
  .sub { font-size: var(--fs-500); margin-bottom: var(--sp-4); }
  .sup-head { margin-top: var(--sp-6); }
  .sup-intro { margin-top: -0.6rem; margin-bottom: var(--sp-4); }
  .teach-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--sp-3); }
  .teach-item { display: flex; gap: var(--sp-4); justify-content: space-between; align-items: flex-start; flex-wrap: wrap; }
  .teach-main { flex: 1 1 340px; }
  .teach-main h3 { font-size: var(--fs-400); }
  .teach-prog { font-size: 0.85rem; margin: 0.2rem 0 0.5rem; }
  .teach-desc { font-size: 0.95rem; max-width: 65ch; }
  .teach-side { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; text-align: right; }
  .teach-years { font-size: 0.85rem; color: var(--muted); }
  .sup-item { display: flex; flex-direction: column; gap: 0.5rem; height: 100%; }
  .sup-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .sup-year { font-size: 0.8rem; color: var(--muted); }
  .sup-title { font-size: var(--fs-400); line-height: 1.25; }
  .sup-project { font-style: italic; color: var(--ink); font-size: 0.92rem; margin: 0; line-height: 1.35; }
  .sup-student { font-size: 0.85rem; color: var(--muted); font-weight: 400; margin: 0; }
  .sup-blurb { font-size: 0.93rem; max-width: none; }
  .sup-link { font-family: var(--font-mono); font-size: 0.76rem; margin-top: auto; padding-top: 0.3rem; text-decoration: none; color: var(--accent-strong); }
  .assess { margin-top: var(--sp-6); }
  .assess-list { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem 1rem; }
  .assess-item { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.7rem 0.9rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); border-left: 3px solid var(--pop); }
  .assess-item.has-title { grid-column: 1 / -1; }
  .assess-name { font-weight: 600; color: var(--ink); }
  .assess-year { color: var(--muted); font-weight: 400; font-size: 0.82rem; }
  .assess-title { font-size: 0.86rem; color: var(--ink); text-decoration: none; line-height: 1.3; }
  .assess-title:hover { color: var(--accent-strong); }
  .assess-prog { font-size: 0.82rem; }
  @media (max-width: 620px) { .teach-side { align-items: flex-start; text-align: left; } .assess-list { grid-template-columns: 1fr; } }
</style>
