---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  { icon: 'chart', title: 'Predictive modelling & simulation', body: 'Forecasting, statistical modelling, surrogate models and uncertainty quantification — turning historical and messy data into models that support real decisions.' },
  { icon: 'brain', title: 'Machine learning & AI solutions', body: 'Building, validating and explaining ML models — and small, dependable tools and pipelines around them — with a scientist’s eye for what actually generalises.' },
  { icon: 'node', title: 'Networks, complex systems & causal inference', body: 'Untangling interconnected systems: network analysis, higher-order interactions and causal reasoning that go beyond pairwise correlations. My core research niche.' },
  { icon: 'teach', title: 'Workshops & training', body: 'Hands-on training and guest lectures in Python/R, modelling and data analysis for teams that want to build the capability in-house.' },
];

const steps = [
  { n: '01', t: 'Frame the real question', d: 'We start from the decision you need to make, not the model. I translate a business or research problem into something tractable.' },
  { n: '02', t: 'Model & validate', d: 'I build the modelling or analysis, and — just as importantly — stress-test it so you know where it holds and where it doesn’t.' },
  { n: '03', t: 'Hand over something usable', d: 'You get results explained in plain terms, plus code or tooling your team can run and maintain after I’m gone.' },
];
---
<Base title="Consulting — Cillian Hourican" description="Independent consulting by Cillian Hourican: computational and predictive modelling, machine learning, network and causal analysis, and training — from a postdoctoral computational scientist.">
  <section class="section container">
    <div class="section-head">
      <p class="eyebrow" style="color: var(--pop-strong)">Consulting · Available for freelance work</p>
      <h1>Computational scientist, working as your modelling consultant.</h1>
      <p class="lede">I help teams turn complex, interconnected data into models they can act on. A PhD-level grounding in statistics, machine learning and networks — applied to your problem, and explained without the jargon.</p>
      <div class="hero-cta">
        <a class="btn btn--pop" href="mailto:c.j.hourican@uva.nl?subject=Consulting%20enquiry">Book a call <span class="arrow" aria-hidden="true">→</span></a>
        <a class="btn btn--ghost" href="/cv">See my background</a>
      </div>
    </div>

    <div class="grid grid-2 svc-grid">
      {services.map((s) => <ServiceCard icon={s.icon} title={s.title} body={s.body} />)}
    </div>
  </section>

  <section class="section--tight container">
    <div class="section-head"><p class="eyebrow">How I work</p></div>
    <div class="grid grid-3 steps">
      {steps.map((s) => (
        <div class="step">
          <span class="step-n mono">{s.n}</span>
          <h3>{s.t}</h3>
          <p class="muted">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section container">
    <div class="cross card">
      <div>
        <p class="eyebrow">Across domains</p>
        <h2>Comfortable in unfamiliar territory.</h2>
        <p class="muted">My research alone has spanned cardiovascular disease, depression, ageing, genomics and the gut microbiome — each a new domain to learn quickly and model rigorously. That range is the point: the methods travel, and I’m used to getting up to speed in a field that isn’t my own.</p>
      </div>
      <div class="cross-side">
        <p class="eyebrow">Also</p>
        <p>I co-founded <a href="https://causalix.ai">CausalixAI</a>, building AI-powered causal-modelling tools — so I bring a product and delivery perspective alongside the research.</p>
      </div>
    </div>
  </section>

  <section class="section--tight container center">
    <h2>Have a problem that lives in the data?</h2>
    <p class="muted">Tell me what you’re trying to decide. An initial conversation is free.</p>
    <div class="hero-cta center-cta">
      <a class="btn btn--pop" href="mailto:c.j.hourican@uva.nl?subject=Consulting%20enquiry">Get in touch <span class="arrow" aria-hidden="true">→</span></a>
    </div>
  </section>
</Base>

<style>
  .svc-grid { margin-top: var(--sp-2); }
  .steps { gap: var(--sp-4); }
  .step { display: flex; flex-direction: column; gap: 0.5rem; }
  .step-n { color: var(--pop-strong); font-size: 1.1rem; font-weight: 500; }
  .step h3 { font-size: var(--fs-400); }
  .cross { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--sp-5); padding: clamp(1.75rem, 4vw, 3rem); }
  .cross h2 { margin: 0.4rem 0 0.7rem; }
  .cross-side { border-left: 1px solid var(--border); padding-left: var(--sp-4); }
  .center { text-align: center; }
  .center h2 { text-wrap: balance; }
  .center p { margin-inline: auto; }
  .center-cta { justify-content: center; }
  @media (max-width: 720px) { .cross { grid-template-columns: 1fr; } .cross-side { border-left: 0; border-top: 1px solid var(--border); padding-left: 0; padding-top: var(--sp-3); } }
</style>
