% ============================================================
% cvstyle.sty — shared style for Cillian Hourican's CVs
% Darjeeling brand: geometric display (Montserrat ~ Jost) + clean
% grotesque body (Source Sans 3 ~ Public Sans), teal + burnt-orange.
% Engine: pdflatex.
% ============================================================
\ProvidesPackage{cvstyle}[2026/07/13 Cillian Hourican CV style]

\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage[a4paper,top=1.4cm,bottom=1.4cm,left=1.7cm,right=1.7cm]{geometry}
\usepackage[default]{sourcesans}   % body font -> Source Sans 3
\usepackage{microtype}
\usepackage{ragged2e}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage{fontawesome5}
\usepackage{academicons}
\usepackage{fancyhdr}
\usepackage{needspace}
\usepackage[hidelinks]{hyperref}

% --- Darjeeling palette (tuned for print on white) ---
\definecolor{cvink}{HTML}{22302E}
\definecolor{cvteal}{HTML}{0B6469}
\definecolor{cvtealsoft}{HTML}{0F7C82}
\definecolor{cvpop}{HTML}{C85A28}
\definecolor{cvmuted}{HTML}{55625D}
\definecolor{cvrule}{HTML}{D8CDB8}

\color{cvink}

% --- heading font: Montserrat (geometric, echoes site Jost) ---
\newcommand{\headfont}{\fontfamily{Montserrat-LF}\selectfont}

\hypersetup{
  colorlinks=true,
  urlcolor=cvteal,
  linkcolor=cvteal,
  pdftitle={Cillian Hourican — CV},
  pdfauthor={Cillian Hourican}
}

% --- section headings (custom, no titlesec) ---
\renewcommand\section[1]{%
  \par\addvspace{7pt}\needspace{3.2\baselineskip}%
  {\headfont\bfseries\large\color{cvteal}\MakeUppercase{#1}}\par\vspace{1.5pt}%
  {\color{cvrule}\rule{\linewidth}{1pt}}\par\nobreak\vspace{3pt}}

% subsection (grouped sub-blocks, e.g. supervision roles)
\renewcommand\subsection[1]{%
  \par\addvspace{4pt}\needspace{2.4\baselineskip}%
  {\headfont\bfseries\normalsize\color{cvpop}#1}\par\vspace{1pt}}

% --- entry (dated two-column row) ---
\newlength{\cvdatew}\setlength{\cvdatew}{2.6cm}
\newlength{\cvgap}\setlength{\cvgap}{0.5cm}
\newlength{\cvbodyw}\setlength{\cvbodyw}{\dimexpr\textwidth-\cvdatew-\cvgap\relax}

\newcommand{\dates}[1]{{\headfont\small\color{cvmuted}#1}}
\newcommand{\etitle}[1]{{\headfont\bfseries\color{cvink}#1}}
\newcommand{\eplace}[1]{{\color{cvtealsoft}#1}}
\newcommand{\edetail}[1]{{\color{cvmuted}\small #1}}

% \entry{dates}{body}
\newcommand{\entry}[2]{%
  \par\vspace{2.5pt}\needspace{2\baselineskip}\noindent
  \begin{minipage}[t]{\cvdatew}\raggedright\dates{#1}\end{minipage}%
  \hspace{\cvgap}%
  \begin{minipage}[t]{\cvbodyw}\RaggedRight #2\end{minipage}\par}

% \skillrow{label}{items}
\newcommand{\skillrow}[2]{%
  \par\vspace{2pt}\noindent
  \begin{minipage}[t]{\cvdatew}\raggedright{\headfont\small\bfseries\color{cvink}#1}\end{minipage}%
  \hspace{\cvgap}%
  \begin{minipage}[t]{\cvbodyw}\RaggedRight #2\end{minipage}\par}

% publication list
\newlist{pubs}{enumerate}{1}
\setlist[pubs]{leftmargin=1.35em,labelsep=0.55em,itemsep=3pt,topsep=1pt,
  label=\textcolor{cvmuted}{\headfont\small\arabic*.}}
\newcommand{\me}[1]{\textbf{#1}}                       % highlight own name
\newcommand{\venue}[1]{\textcolor{cvtealsoft}{#1}}     % journal name
\newcommand{\doilink}[1]{\href{https://doi.org/#1}{\textcolor{cvmuted}{\small doi:#1}}}

% plain tight bullet list
\setlist[itemize]{leftmargin=1.2em,itemsep=1pt,topsep=1pt,parsep=0pt}

% --- footer ---
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[L]{\headfont\footnotesize\color{cvmuted}Cillian Hourican}
\fancyfoot[R]{\headfont\footnotesize\color{cvmuted}\thepage}

% --- header block: \cvheader{tagline}{contact-line} ---
\newcommand{\cvheader}[2]{%
  {\headfont\bfseries\fontsize{30}{34}\selectfont\color{cvteal}Cillian Hourican}\par
  \vspace{3pt}
  {\headfont\normalsize\color{cvpop}#1}\par
  \vspace{6pt}
  {\small\color{cvmuted}#2}\par
  \vspace{5pt}
  {\color{cvrule}\rule{\linewidth}{1.2pt}}\par
}

\setlength{\parindent}{0pt}
\RaggedRight
